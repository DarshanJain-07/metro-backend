# Django core configuration
DJANGO_SECRET_KEY=generate_a_secure_random_key_here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ORIGINS=http://localhost:3000

# Django/PostgreSQL configuration
# Copy this file to .env and fill in client-specific values before running the app.

METRO_DB_NAME=client_database_name
METRO_DB_USER=postgres
METRO_DB_PASSWORD=change_me
METRO_DB_HOST=localhost
METRO_DB_PORT=5432

# Redis cache/throttle backend
REDIS_URL=redis://127.0.0.1:6379/1

# JWT token lifetimes
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# Format for auto-generating docket numbers. 
# Available placeholders: {YY}, {YYYY}, {MM}, {DD}, {SEQ:N} (where N is the zero-padded length)
DOCKET_FORMAT=D{YY}{MM}{DD}{SEQ:4}
